          "model": "Qwen/Qwen3-32B",
          "backend": "vllm",
          "request-rate": "inf",
          "dataset-name": "custom",
          "num-prompts": 1000,
          "percentile-metrics": "ttft,tpot,itl,e2el",
          "ignore-eos": true,
          "skip-chat-template": true,
          "dataset-path": "/workspace/tpu_inference/artifacts/dataset/Qwen3-32B/inlen2048_outlen8192_prefixlen0.jsonl",
