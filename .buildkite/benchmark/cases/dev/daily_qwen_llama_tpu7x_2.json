{
  "global_env": {
    "GCP_PROJECT_ID": "cloud-tpu-inference-test",
    "GCS_BUCKET": "vllm-cb-storage2",
    "MODELTAG": "NEW",
    "EXPECTED_ETEL": 43200000,
    "USE_MOE_EP_KERNEL": 0,
    "MODEL_IMPL_TYPE": "vllm"
  },
  "benchmark_cases": [
    {
      "case_name": "Llama-3.1-8B-Instruct-dataset_custom-inlen_4096-outlen_1024-additionconfig-Test-bm-time",
      "env": {
        "MODELTAG": "NEW",
        "EXPECTED_ETEL": 3600000,
        "INPUT_LEN": 4096,
        "OUTPUT_LEN": 1024,
        "PREFIX_LEN": 3600
      },
      "ci_queue": [
        "tpu_v7x_2_queue"
      ],
      "server_command_options": {
        "command_type": "vllm_serve",
        "env": {
          "VLLM_USE_V1": "1"
        },
        "args": {
          "model": "meta-llama/Llama-3.1-8B-Instruct",
          "seed": 42,
          "max-num-seqs": 1024,
          "max-num-batched-tokens": 4096,
          "tensor-parallel-size": {
            "v7x-2": 2
          },
          "no-enable-prefix-caching": true,
          "max-model-len": 5120,
          "async-scheduling": true,
          "additional-config": "{\"quantization\": { \"qwix\": { \"rules\": [{ \"module_path\": \".*\", \"weight_qtype\": \"float8_e4m3fn\", \"act_qtype\": \"float8_e4m3fn\"}]}}}"
        }
      },
      "client_command_options": {
        "command_type": "vllm_bench_serve",
        "args": {
          "model": "meta-llama/Llama-3.1-8B-Instruct",
          "backend": "vllm",
          "request-rate": "inf",
          "dataset-name": "custom",
          "num-prompts": 1000,
          "percentile-metrics": "ttft,tpot,itl,e2el",
          "ignore-eos": true,
          "skip-chat-template": true,
          "dataset-path": "/workspace/tpu_inference/artifacts/dataset/Llama-3.1-8B-Instruct/inlen4096_outlen1024_prefixlen3600.jsonl",
          "custom-output-len": 1024
        }
      }
    }
  ]
}