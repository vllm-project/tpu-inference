{
  "global_env": {
    "GCP_PROJECT_ID": "cloud-tpu-inference-test",
    "GCS_BUCKET": "vllm-cb-storage2",
    "GCP_INSTANCE_ID": "vllm-bm-inst",
    "GCP_DATABASE_ID": "vllm-bm-bk-runs"
  },
  "benchmark_cases": [
    {
      "case_name": "Qwen3-Coder-480B-A35B-Instruct-FP8-dataset_random-inlen_1024-outlen_1024-MaxModelLen_10240",
      "ci_queue": [
        "tpu_v7x_8_queue"
      ],
      "env": {
        "MODELTAG": "PROD",
        "EXPECTED_ETEL": 3600000,
        "INPUT_LEN": 1024,
        "OUTPUT_LEN": 1024,
        "PREFIX_LEN": 0
      },
      "server_command_options": {
        "command_type": "vllm_serve",
        "env": {
          "VLLM_USE_V1": "1",
          "MODEL_IMPL_TYPE": "vllm",
          "USE_MOE_SPARSE_CORE": 0
        },
        "args": {
          "model": "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8",
          "seed": 42,
          "max-num-seqs": 512,
          "max-num-batched-tokens": 8192,
          "tensor-parallel-size": {
            "v7x-8": 8
          },
          "no-enable-prefix-caching": true,
          "max-model-len": 10240,
          "kv-cache-dtype": "fp8",
          "gpu-memory-utilization": 0.95,
          "enable-expert-parallel": true,
          "async-scheduling": true,
          "quantization":"fp8",
          "attention-backend":"CUSTOM"
        }
      },
      "client_command_options": {
        "command_type": "vllm_bench_serve",
        "args": {
          "model": "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8",
          "backend": "vllm",
          "request-rate": "inf",
          "dataset-name": "random",
          "num-prompts": 320,
          "random-input-len": 1024,
          "random-output-len": 1024,
          "percentile-metrics": "ttft,tpot,itl,e2el",
          "ignore-eos": true,
          "temperature": 0
        }
      }
    },
    {
      "case_name": "Qwen3-Coder-480B-A35B-Instruct-FP8-dataset_random-inlen_1024-outlen_1024-MaxModelLen_16384",
      "ci_queue": [
