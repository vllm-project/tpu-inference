{
  "global_env": {
    "GCP_PROJECT_ID": "cloud-tpu-inference-test",
    "GCS_BUCKET": "vllm-cb-storage2",
    "GCP_INSTANCE_ID": "vllm-bm-inst",
    "GCP_DATABASE_ID": "vllm-bm-bk-runs",
    "MODELTAG": "NEW",
    "EXPECTED_ETEL": 43200000,
    "USE_MOE_EP_KERNEL": 0,
    "MODEL_IMPL_TYPE": "vllm"
  },
  "benchmark_cases": [
    {
      "case_name": "Qwen3-Coder-480B-A35B-Instruct-FP8-dataset_random-inlen_8192-outlen_1",
      "env": {
        "INPUT_LEN": 8192,
        "OUTPUT_LEN": 1,
        "PREFIX_LEN": 0
      },
      "ci_queue": [
        "tpu_v7x_8_queue"
      ],
      "server_command_options": {
        "command_type": "vllm_serve",
        "env": {
          "VLLM_USE_V1": "1"
        },
        "args": {
          "model": "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8",
          "seed": 42,
          "max-num-seqs": 64,
          "max-num-batched-tokens": 8192,
          "tensor-parallel-size": {
            "v7x-8": 8
          },
          "no-enable-prefix-caching": true,
          "max-model-len": 10240,
          "kv-cache-dtype": "fp8",
          "gpu-memory-utilization": 0.95,
          "block-size": 64,
          "async-scheduling": true
        }
      },
      "client_command_options": {
        "command_type": "vllm_bench_serve",
        "args": {
          "model": "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8",
          "backend": "vllm",
          "request-rate": "0.2",
          "dataset-name": "random",
          "num-prompts": 50,
          "percentile-metrics": "ttft,tpot,itl,e2el",
          "ignore-eos": true,
          "random-input-len": 8192,
          "random-output-len": 1,
          "random-range-ratio": 0.8,
          "max-concurrency": 64,
          "metric-percentiles": "90,95,99"
        }
      }
    },
