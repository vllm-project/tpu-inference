  "benchmark_cases": [
    {
      "case_name": "Qwen3_5-397B-A17B-FP8-dataset_random-inlen_1024-outlen_1024",
      "ci_queue": [
        "tpu_v7x_8_queue"
      ],
      "env": {
        "MODELTAG": "NEW",
        "EXPECTED_ETEL": 43200000,
        "INPUT_LEN": 1024,
        "OUTPUT_LEN": 1024,
        "PREFIX_LEN": 0
      },
      "server_command_options": {
        "command_type": "vllm_serve",
        "env": {
          "VLLM_USE_V1": "1",
          "MODEL_IMPL_TYPE": "vllm"
        },
        "args": {
          "model": "Qwen/Qwen3.5-397B-A17B-FP8",
          "max-num-seqs": 8,
          "max-num-batched-tokens": 4096,
          "tensor-parallel-size": {
            "v7x-8": 8,
            "default": 8
          },
          "max-model-len": 2048,
          "kv-cache-dtype": "fp8",
          "gpu-memory-utilization": 0.9,
          "block-size": 256
        }
      },
      "client_command_options": {
        "command_type": "vllm_bench_serve",
        "args": {
          "model": "Qwen/Qwen3.5-397B-A17B-FP8",
          "backend": "vllm",
          "dataset-name": "random",
          "num-prompts": 320,
          "random-input-len": 1024,
          "random-output-len": 1024,
          "max-concurrency": 320,
          "request-rate": "inf",
          "ignore-eos": true,
          "percentile-metrics": "ttft,tpot,itl,e2el"
        }
      }
    },
