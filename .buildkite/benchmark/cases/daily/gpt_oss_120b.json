  "benchmark_cases": [
    {
      "case_name": "gpt-oss-120b-BF16-dataset_random-inlen_2048-outlen_6144",
      "ci_queue": [
        "tpu_v7x_8_queue"
      ],
      "env": {
        "RUN_TYPE": "DAILY",
        "MODELTAG": "NEW",
        "EXPECTED_ETEL": 43200000,
        "INPUT_LEN": 2048,
        "OUTPUT_LEN": 6144,
        "PREFIX_LEN": 0
      },
      "server_command_options": {
        "command_type": "vllm_serve",
        "env": {
          "VLLM_USE_V1": "1",
          "MODEL_IMPL_TYPE": "vllm",
          "USE_MOE_EP_KERNEL": "0",
          "TPU_MULTIPROCESS_DP": "0"
        },
        "args": {
          "model": "unsloth/gpt-oss-120b-BF16",
          "seed": 42,
          "max-num-seqs": 500,
          "max-num-batched-tokens": 16384,
          "tensor-parallel-size": {
            "v7x-8": 4
          },
          "data-parallel-size": 2,
          "max-model-len": 8192,
          "gpu-memory-utilization": 0.98,
          "no-enable-prefix-caching": true,
          "async-scheduling": true
        }
      },
      "client_command_options": {
        "command_type": "vllm_bench_serve",
        "args": {
          "model": "unsloth/gpt-oss-120b-BF16",
          "backend": "vllm",
          "request-rate": "inf",
          "dataset-name": "random",
          "num-prompts": 1000,
          "percentile-metrics": "ttft,tpot,itl,e2el",
          "ignore-eos": true,
          "random-input-len": 2048,
          "random-output-len": 6144
        }
      }
    },
