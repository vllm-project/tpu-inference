# Dockerfile for colocated-python sidecar with vllm + tpu-inference
#
# Extends the base Pathways colocated-python sidecar image to include
# vllm (at tpu-inference LKG commit) and tpu-inference packages, so that
# colocated python functions can import tpu-inference code (e.g. for
# distributed weight loading via safetensors).
#
# Build:
#   docker build -f Dockerfile.colocated-python-sidecar \
#     -t us-east5-docker.pkg.dev/cloud-tpu-inference-test/wenxindong/colocated_python:latest .
#
# Push:
#   docker push us-east5-docker.pkg.dev/cloud-tpu-inference-test/wenxindong/colocated_python:latest

FROM us-docker.pkg.dev/cloud-tpu-v2-images/pathways-colocated-python/sidecar:2026_03_16-python_3.12-jax_0.9.1

# Install git (needed for cloning repos) and uv (fast pip replacement)
RUN apt-get update && apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir uv

WORKDIR /workspace

# Clone tpu-inference and read the vllm LKG commit hash
RUN git clone https://github.com/vllm-project/tpu-inference.git
RUN export VLLM_COMMIT_HASH="$(cat tpu-inference/.buildkite/vllm_lkg.version)" && \
    git clone https://github.com/vllm-project/vllm.git && \
    cd vllm && \
    git checkout "${VLLM_COMMIT_HASH}"

# Install vllm (TPU target)
RUN uv pip install --system -r requirements/tpu.txt && \
    VLLM_TARGET_DEVICE="tpu" uv pip install --system -e .

# Install tpu-inference
RUN cd tpu-inference && \
    uv pip install --system -e .

# Verify the installation
RUN python -c '\
import jax; \
import vllm; \
import safetensors; \
import importlib.metadata; \
tpu_version = importlib.metadata.version("tpu_inference"); \
print(f"vllm version: {vllm.__version__}"); \
print(f"tpu_inference version: {tpu_version}"); \
print(f"jax version: {jax.__version__}"); \
print(f"safetensors version: {safetensors.__version__}"); \
'
